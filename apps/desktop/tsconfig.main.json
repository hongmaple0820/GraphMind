{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/main",
    "rootDir": "../../",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@shared/parser/*": ["../../packages/shared/src/parser/*"],
      "@shared/types/*": ["../../packages/shared/src/types/*"]
    }
  },
  "include": ["src/main", "src/main/**/*.ts", "../../packages/shared/src"]
}
